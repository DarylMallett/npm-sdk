{
  "name": "mailchk",
  "version": "1.0.0",
  "description": "Official Mailchk SDK - Email validation API to detect disposable, temporary, and invalid emails",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "email",
    "validation",
    "email-validation",
    "disposable-email",
    "temporary-email",
    "email-verification",
    "email-checker",
    "burner-email",
    "mx-record",
    "email-api",
    "mailchk"
  ],
  "author": "Mailchk <support@mailchk.io>",
  "license": "MIT",
  "homepage": "https://mailchk.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mailchk/mailchk-js"
  },
  "bugs": {
    "url": "https://github.com/mailchk/mailchk-js/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
