{
  "name": "mailchk",
  "version": "1.2.0",
  "description": "Official Mailchk SDK - Email validation API to detect disposable, temporary, and invalid emails",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run lint"
  },
  "keywords": [
    "email",
    "validation",
    "email-validation",
    "disposable-email",
    "temporary-email",
    "email-verification",
    "email-checker",
    "burner-email",
    "mx-record",
    "email-api",
    "mailchk"
  ],
  "author": "Mailchk <support@mailchk.io>",
  "license": "MIT",
  "homepage": "https://mailchk.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/mailchk/mailchk-js"
  },
  "bugs": {
    "url": "https://github.com/mailchk/mailchk-js/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.6.0",
    "jest-fetch-mock": "^3.0.3",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": ["jest-fetch-mock"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
